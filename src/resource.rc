VS_VERSION_INFO VERSIONINFO
FILEVERSION 2026,6,14,0
PRODUCTVERSION 2026,6,14,0
FILEFLAGSMASK 0x3F
FILEFLAGS 0x0
FILEOS VOS__WINDOWS32
FILETYPE VFT_APP
FILESUBTYPE VFT2_UNKNOWN
{
  BLOCK "StringFileInfo"
  {
    BLOCK "040904B0"
    {
      VALUE "FileDescription", "ESP Chip Device Simulator\0"
      VALUE "FileVersion", "2026.6.14.0\0"
