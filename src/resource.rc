  }
}

/* ============================================================ */
/* Simplified Chinese (CN)                                                 */
/* ============================================================ */

LANGUAGE LANG_CHINESE_SIMPLIFIED,SUBLANG_CHINESE_SIMPLIFIED

IDR_MAIN_MENU MENUEX
{
  POPUP "设备(&D)", 0, 0, 0
  {
    MENUITEM "新设备(&N)...        Ctrl+N", IDM_NEW_DEVICE, 0, 0
    MENUITEM "打开设备(&O)...      Ctrl+O", IDM_OPEN_DEVICE, 0, 0
    MENUITEM "保存设备(&S)         Ctrl+S", IDM_SAVE_DEVICE, 0, 0
    MENUITEM "设备另存为(&A)...    F12", IDM_SAVE_DEVICE_AS, 0, 0
    MENUITEM "", 0, 0|MFT_SEPARATOR, 0
    MENUITEM "导出设备到文本文件...", IDM_DUMP_DEVICE_AS, 0, 0
    MENUITEM "", 0, 0|MFT_SEPARATOR, 0
    MENUITEM "设备属性(&P)...", IDM_DEVICE_PROPS, 0, 0
    MENUITEM "", 0, 0|MFT_SEPARATOR, 0
    MENUITEM "退出(&X)             Alt+F4", IDM_EXIT, 0, 0
  }
  POPUP "串口(&S)", 0, 0, 0
  {
    MENUITEM "连接(&C)", IDM_CONNECT, 0, 0
    MENUITEM "重新连接(&R)         Ctrl+R", IDM_RECONNECT, 0, 0|MFS_GRAYED
    MENUITEM "", 0, 0|MFT_SEPARATOR, 0
    MENUITEM "断开链接(&D)", IDM_DISCONNECT, 0, 0|MFS_GRAYED
  }
  POPUP "存储(&T)", 0, 0, 0
  {
    MENUITEM "导入 Flash(&I)...", IDM_FLASH_IMPORT, 0, 0
    MENUITEM "导出 Flash(&E)...", IDM_FLASH_EXPORT, 0, 0
    MENUITEM "", 0, 0|MFT_SEPARATOR, 0
    MENUITEM "密钥管理(&K)...", IDM_KEY_MGMT, 0, 0
  }
  POPUP "日志(&L)", 0, 0, 0
  {
    MENUITEM "清除(&C)             Ctrl+L", IDM_LOG_CLEAR, 0, 0
    MENUITEM "另存为(&A)...", IDM_LOG_SAVEAS, 0, 0
    MENUITEM "", 0, 0|MFT_SEPARATOR, 0
    MENUITEM "字体(&F)...", IDM_LOG_FONT, 0, 0
  }
  POPUP "帮助(&H)", 0, 0, 0
  {
    MENUITEM "关于(&A)             F1", IDM_ABOUT, 0, 0
  }
}

IDR_MAIN_ACCEL ACCELERATORS
{
  VK_F1,      IDM_ABOUT,          VIRTKEY
  VK_F12,     IDM_SAVE_DEVICE_AS, VIRTKEY
  "N",        IDM_NEW_DEVICE,     VIRTKEY, CONTROL
  "O",        IDM_OPEN_DEVICE,    VIRTKEY, CONTROL
  "S",        IDM_SAVE_DEVICE,    VIRTKEY, CONTROL
  "R",        IDM_RECONNECT,      VIRTKEY, CONTROL
  "L",        IDM_LOG_CLEAR,      VIRTKEY, CONTROL
}

IDD_PORT_SELECT DIALOGEX 0, 0, 280, 100
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "选择端口"
FONT 8, "MS Shell Dlg"
BEGIN
    COMBOBOX        IDC_PORT_COMBO, 50, 10, 220, 200, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "端口(&P)：", -1, 10, 13, 35, 8
    LTEXT           "波特率：115200（固定）", -1, 10, 35, 260, 8
    LTEXT           "数据位：8   校验：无   停止位：1", -1, 10, 50, 260, 8
    DEFPUSHBUTTON   "确定", IDOK, 100, 75, 50, 14
    PUSHBUTTON      "取消", IDCANCEL, 170, 75, 50, 14
END

IDD_ABOUT DIALOGEX 0, 0, 220, 100
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "关于 FakeEsptool"
FONT 8, "MS Shell Dlg"
BEGIN
    ICON            IDI_APP, -1, 10, 10, 20, 20
    CONTROL         "FakeEsptool v2026.6.14", IDD_APPNAME, "Static", WS_GROUP, 40, 10, 170, 10
    CONTROL         "版权所有 (c) 2026 Larry Li", IDD_COPYRIGHT, "Static", WS_GROUP, 40, 22, 170, 10
    DEFPUSHBUTTON   "确定", IDOK, 85, 78, 50, 14
    CONTROL         "<a href=""https://github.com/larryli/FakeEsptool"">https://github.com/larryli/FakeEsptool</a>", IDD_WEBSITE, "SysLink", WS_TABSTOP, 40, 38, 170, 10
END

IDD_DEVICE_PROPS DIALOGEX 0, 0, 260, 110
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "设备属性"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT           "芯片(&C)：", -1, 10, 12, 50, 8
    COMBOBOX        IDC_CHIP_COMBO, 65, 10, 185, 120, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    LTEXT           "晶振(&X)：", -1, 10, 30, 50, 8
    COMBOBOX        IDC_XTAL_FREQ_COMBO, 65, 28, 185, 80, CBS_DROPDOWNLIST | WS_TABSTOP

    LTEXT           "Flash 大小(&F)：", -1, 10, 48, 50, 8
    COMBOBOX        IDC_FLASH_SIZE_COMBO, 65, 46, 185, 120, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    LTEXT           "MAC(&M)：", -1, 10, 66, 50, 8
    EDITTEXT        IDC_MAC_EDIT, 65, 64, 120, 14, ES_AUTOHSCROLL
    PUSHBUTTON      "随机(&R)", IDC_RANDOM_MAC, 190, 63, 60, 16

    DEFPUSHBUTTON   "确定(&O)", IDOK, 75, 88, 55, 16
    PUSHBUTTON      "取消", IDCANCEL, 140, 88, 55, 16
END

IDD_KEY_MGMT DIALOGEX 0, 0, 380, 230
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "密钥管理"
FONT 8, "MS Shell Dlg"
BEGIN
    CONTROL         "", IDC_KEY_LIST, "SysListView32",
                    0x0001 | 0x0004 | 0x0008 | 0x00800000 | 0x00100000,
                    10, 10, 360, 140

    LTEXT           "密钥数据(&D)：", -1, 10, 158, 50, 8
    EDITTEXT        IDC_KEY_HEX, 65, 156, 305, 14, ES_AUTOHSCROLL | ES_READONLY

    PUSHBUTTON      "导入(&I)...", IDC_KEY_IMPORT, 10, 180, 60, 16
    PUSHBUTTON      "导出(&X)...", IDC_KEY_EXPORT, 75, 180, 60, 16
    PUSHBUTTON      "生成(&G)", IDC_KEY_GENERATE, 140, 180, 60, 16
    PUSHBUTTON      "清除(&L)", IDC_KEY_CLEAR, 205, 180, 60, 16

    DEFPUSHBUTTON   "关闭(&C)", IDC_KEY_CLOSE, 160, 205, 60, 16
END

