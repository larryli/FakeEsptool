/*
 * resource.rc - Resource file for FakeEsptool
 *
 * English (US) resources with LANGUAGE directive support for future i18n.
 */

#include <windows.h>
#include <commctrl.h>
#include "resource.h"

/* Shared resources (language independent) */
IDI_APP ICON "res/app.ico"
IDB_TOOLBAR BITMAP "res/toolbar.bmp"
1 RT_MANIFEST "res/res1.xml"

/* ============================================================ */
/* English (US)                                                 */
/* ============================================================ */

LANGUAGE LANG_ENGLISH,SUBLANG_ENGLISH_US

IDR_MAIN_MENU MENUEX
{
  POPUP "&Device", 0, 0, 0
  {
    MENUITEM "&New Device...       Ctrl+N", IDM_NEW_DEVICE, 0, 0
    MENUITEM "&Open Device...      Ctrl+O", IDM_OPEN_DEVICE, 0, 0
    MENUITEM "&Save Device         Ctrl+S", IDM_SAVE_DEVICE, 0, 0
    MENUITEM "Save Device &As...   F12", IDM_SAVE_DEVICE_AS, 0, 0
    MENUITEM "", 0, 0|MFT_SEPARATOR, 0
    MENUITEM "Dump Device As...", IDM_DUMP_DEVICE_AS, 0, 0
    MENUITEM "", 0, 0|MFT_SEPARATOR, 0
    MENUITEM "Device &Properties...", IDM_DEVICE_PROPS, 0, 0
    MENUITEM "", 0, 0|MFT_SEPARATOR, 0
    MENUITEM "E&xit                Alt+F4", IDM_EXIT, 0, 0
  }
  POPUP "&Serial", 0, 0, 0
  {
    MENUITEM "&Connect", IDM_CONNECT, 0, 0
    MENUITEM "&Reconnect          Ctrl+R", IDM_RECONNECT, 0, 0|MFS_GRAYED
    MENUITEM "", 0, 0|MFT_SEPARATOR, 0
    MENUITEM "&Disconnect", IDM_DISCONNECT, 0, 0|MFS_GRAYED
  }
  POPUP "&Storage", 0, 0, 0
  {
    MENUITEM "&Import Flash...", IDM_FLASH_IMPORT, 0, 0
    MENUITEM "&Export Flash...", IDM_FLASH_EXPORT, 0, 0
    MENUITEM "", 0, 0|MFT_SEPARATOR, 0
    MENUITEM "&Key Management...", IDM_KEY_MGMT, 0, 0
  }
  POPUP "&Log", 0, 0, 0
  {
    MENUITEM "&Clear               Ctrl+L", IDM_LOG_CLEAR, 0, 0
    MENUITEM "Save &as...", IDM_LOG_SAVEAS, 0, 0
    MENUITEM "", 0, 0|MFT_SEPARATOR, 0
    MENUITEM "&Font...", IDM_LOG_FONT, 0, 0
  }
  POPUP "&Help", 0, 0, 0
  {
    MENUITEM "&About               F1", IDM_ABOUT, 0, 0
  }
}

IDR_MAIN_ACCEL ACCELERATORS
{
  VK_F1,      IDM_ABOUT,          VIRTKEY
  VK_F12,     IDM_SAVE_DEVICE_AS, VIRTKEY
  "N",        IDM_NEW_DEVICE,     VIRTKEY, CONTROL
  "O",        IDM_OPEN_DEVICE,    VIRTKEY, CONTROL
  "S",        IDM_SAVE_DEVICE,    VIRTKEY, CONTROL
  "R",        IDM_RECONNECT,      VIRTKEY, CONTROL
  "L",        IDM_LOG_CLEAR,      VIRTKEY, CONTROL
}

IDD_PORT_SELECT DIALOGEX 0, 0, 280, 100
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Select Port"
FONT 8, "MS Shell Dlg"
BEGIN
    COMBOBOX        IDC_PORT_COMBO, 50, 10, 220, 200, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "&Port:", -1, 10, 13, 35, 8
    LTEXT           "Baud Rate: 115200 (Fixed)", -1, 10, 35, 260, 8
    LTEXT           "Data: 8   Parity: None   Stop: 1", -1, 10, 50, 260, 8
    DEFPUSHBUTTON   "OK", IDOK, 100, 75, 50, 14
    PUSHBUTTON      "Cancel", IDCANCEL, 170, 75, 50, 14
END

IDD_ABOUT DIALOGEX 0, 0, 220, 100
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "About FakeEsptool"
FONT 8, "MS Shell Dlg"
BEGIN
    ICON            IDI_APP, -1, 10, 10, 20, 20
    CONTROL         "FakeEsptool v2026.6.14", IDD_APPNAME, "Static", WS_GROUP, 40, 10, 170, 10
    CONTROL         "Copyright (c) 2026 Larry Li", IDD_COPYRIGHT, "Static", WS_GROUP, 40, 22, 170, 10
    DEFPUSHBUTTON   "OK", IDOK, 85, 78, 50, 14
    CONTROL         "<a href=""https://github.com/larryli/FakeEsptool"">https://github.com/larryli/FakeEsptool</a>", IDD_WEBSITE, "SysLink", WS_TABSTOP, 40, 38, 170, 10
END

IDD_DEVICE_PROPS DIALOGEX 0, 0, 260, 110
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Device Properties"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT           "&Chip:", -1, 10, 12, 50, 8
    COMBOBOX        IDC_CHIP_COMBO, 65, 10, 185, 120, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    LTEXT           "&XTAL:", -1, 10, 30, 50, 8
    COMBOBOX        IDC_XTAL_FREQ_COMBO, 65, 28, 185, 80, CBS_DROPDOWNLIST | WS_TABSTOP

    LTEXT           "&Flash Size:", -1, 10, 48, 50, 8
    COMBOBOX        IDC_FLASH_SIZE_COMBO, 65, 46, 185, 120, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    LTEXT           "&MAC:", -1, 10, 66, 50, 8
    EDITTEXT        IDC_MAC_EDIT, 65, 64, 120, 14, ES_AUTOHSCROLL
    PUSHBUTTON      "&Random", IDC_RANDOM_MAC, 190, 63, 60, 16

    DEFPUSHBUTTON   "&OK", IDOK, 75, 88, 55, 16
    PUSHBUTTON      "Cancel", IDCANCEL, 140, 88, 55, 16
END

IDD_KEY_MGMT DIALOGEX 0, 0, 380, 230
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Key Management"
FONT 8, "MS Shell Dlg"
BEGIN
    CONTROL         "", IDC_KEY_LIST, "SysListView32",
                    0x0001 | 0x0004 | 0x0008 | 0x00800000 | 0x00100000,
                    10, 10, 360, 140

    LTEXT           "Key &Data:", -1, 10, 158, 50, 8
    EDITTEXT        IDC_KEY_HEX, 65, 156, 305, 14, ES_AUTOHSCROLL | ES_READONLY

    PUSHBUTTON      "&Import...", IDC_KEY_IMPORT, 10, 180, 60, 16
    PUSHBUTTON      "E&xport...", IDC_KEY_EXPORT, 75, 180, 60, 16
    PUSHBUTTON      "&Generate", IDC_KEY_GENERATE, 140, 180, 60, 16
    PUSHBUTTON      "C&lear", IDC_KEY_CLEAR, 205, 180, 60, 16

    DEFPUSHBUTTON   "&Close", IDC_KEY_CLOSE, 160, 205, 60, 16
END

